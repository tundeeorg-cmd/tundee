# TunDee — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is listed in .gitignore.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Server-only — used for admin writes and the immutable baseline snapshot API.
# Never expose this in client-side code or commit it to the repo.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email address of the admin user (must match a Supabase auth user).
# The admin dashboard and import API check this value server-side.
NEXT_PUBLIC_ADMIN_EMAIL=your@email.com

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# If unset, GA is disabled and no tracking script is loaded.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Email / Resend (optional) ─────────────────────────────────────────────────
# API key for deadline reminder emails sent via Resend (resend.com).
# Required only if you want the reminder cron to work.
RESEND_API_KEY=re_...
