# TunDee — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is listed in .gitignore.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Server-only — used for admin writes and the immutable baseline snapshot API.
# Never expose this in client-side code or commit it to the repo.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email address of the admin user (must match a Supabase auth user).
# The admin dashboard and import API check this value server-side.
NEXT_PUBLIC_ADMIN_EMAIL=your@email.com

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# If unset, GA is disabled and no tracking script is loaded.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Email / Resend (optional) ─────────────────────────────────────────────────
# API key for deadline reminder emails sent via Resend (resend.com).
# Required only if you want the reminder cron to work.
RESEND_API_KEY=re_...

# ── Site URL ─────────────────────────────────────────────────────────────────
# Canonical production URL — used for general links (not the LINE
# redirect_uri; see LINE_REDIRECT_URI below).
NEXT_PUBLIC_SITE_URL=https://www.tundee.org

# ── LINE Messaging API (bot / webhook / push) ──────────────────────────────────
# Get these from: LINE Developers Console → your Messaging API channel
# LINE_CHANNEL_ACCESS_TOKEN – long-lived channel access token, used to push/reply
# LINE_CHANNEL_SECRET       – used to verify the x-line-signature webhook header
LINE_CHANNEL_ACCESS_TOKEN=...
LINE_CHANNEL_SECRET=...

# ── LINE Login (Connect LINE / account linking) ────────────────────────────────
# Get these from: LINE Developers Console → your LINE Login channel
LINE_LOGIN_CHANNEL_ID=...
LINE_LOGIN_CHANNEL_SECRET=...

# Exact redirect_uri registered in LINE Developers Console → LINE Login
# channel → Callback URL. Must be byte-identical between the authorize
# request and the token exchange — this is that single source of truth.
# Falls back to http://localhost:3000/api/line/callback in local dev only.
LINE_REDIRECT_URI=https://www.tundee.org/api/line/callback

# LINE's "add as friend" prompt style during login: normal | aggressive.
# aggressive only does anything if this Login channel has a Linked OA —
# leave unset for normal.
LINE_BOT_PROMPT=

# ── Cron auth ────────────────────────────────────────────────────────────────
# Shared secret checked against the `Authorization: Bearer <CRON_SECRET>`
# header on every /api/cron/* route. Vercel Cron Jobs attach this header
# automatically when CRON_SECRET is set as a project env var.
CRON_SECRET=...

# ── LINE reminder / outcome-followup tuning (optional) ─────────────────────────
# Days before deadline_date to send a deadline reminder (default "14,1").
REMINDER_OFFSETS=14,1
# Days after deadline_date to ask whether the student won the scholarship
# (default "30,60,90"; capped at 3 attempts).
OUTCOME_OFFSETS=30,60,90
# Optional one-line note appended to the outcome-followup question, e.g. a
# thank-you or small incentive, to lift response rate. Leave unset to omit.
OUTCOME_FOLLOWUP_INCENTIVE_NOTE=
