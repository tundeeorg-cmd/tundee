{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/send-reminders",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/line-reminders",
      "schedule": "0 1 * * *"
    }
  ]
}
